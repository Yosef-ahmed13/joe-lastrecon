# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# GitHub
GH_TOKEN=YOUR_GITHUB_PAT_HERE
GITHUB_REPO=Yosef-ahmed13/joe-lastrecon
BATCH_SIZE=30

# API Keys (optional — improves results)
SHODAN_API_KEY=
CHAOS_KEY=
VIRUSTOTAL_API_KEY=
GITHUB_RECON_TOKEN=
CENSYS_API_ID=
CENSYS_API_SECRET=
BINARYEDGE_KEY=
SECURITYTRAILS_KEY=
FOFA_EMAIL=
FOFA_KEY=
